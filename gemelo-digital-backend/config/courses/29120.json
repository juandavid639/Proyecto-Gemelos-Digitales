  "prescription": {
    "rules": [
      {
        "when": { "code": "C.1.4", "belowPct": 70 },
        "do": {
          "routeId": "R-C1-viabilidad",
          "title": "Refuerzo en viabilidad técnica/operativa/organizacional",
          "actions": [
            "Checklist de datos, capacidades y riesgos",
            "Mini-caso: restricciones y plan de mitigación",
            "Matriz de viabilidad (datos, operación, gobierno)"
          ]
        }
      },
      {
        "when": { "code": "C.1.6", "belowPct": 50 },
        "do": {
          "routeId": "R-C1-priorizacion",
          "title": "Refuerzo en priorización y decisión estratégica con IA",
          "actions": [
            "Plantilla de matriz impacto–riesgo (2x2)",
            "Caso corto: elegir 1 iniciativa y justificar trade-offs",
            "Evidencia: criterio de priorización + recomendación ejecutiva"
          ]
        }
      }
    ]
  }
